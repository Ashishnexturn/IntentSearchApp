@model SearchResultViewModel

@{
    ViewData["Title"] = "Category Search Results";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-12">
            <h1 class="display-5 mb-4">Category Search Results</h1>

            <!-- Search Summary Card -->
            <div class="card mb-4 border-warning">
                <div class="card-header bg-warning text-dark">
                    <h5 class="mb-0">Search Summary</h5>
                </div>
                <div class="card-body">
                    <p><strong>Your Query:</strong> <span class="text-info">@Model.SearchQuery</span></p>
                    <p><strong>Detected Intent:</strong> <span class="badge bg-warning text-dark">@Model.Intent.Intent</span></p>
                    <p><strong>Keyword:</strong> <span class="badge bg-info">@Model.Intent.Keyword</span></p>
                    <p class="mb-0"><strong>Products Found:</strong> <span class="badge bg-secondary">@Model.TotalProducts</span></p>
                </div>
            </div>

            <!-- Products Grid -->
            @if (Model.Products.Any())
            {
                <div class="row">
                    @foreach (var product in Model.Products.Take(12))
                    {
                        <div class="col-md-6 col-lg-4 mb-4">
                            <div class="card h-100 shadow-sm">
                                <div class="card-header bg-light">
                                    <span class="badge bg-warning">@product.Category</span>
                                </div>
                                <div class="card-body">
                                    <h5 class="card-title">@product.Name</h5>
                                    <p class="card-text text-muted small">@product.Description</p>
                                </div>
                                <div class="card-footer bg-light">
                                    <div class="d-flex justify-content-between">
                                        <span class="text-success fw-bold">${@product.Price.ToString("F2")}</span>
                                        <button class="btn btn-sm btn-warning" disabled>View</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="alert alert-info">No categories matched your search.</div>
            }
            
            <div class="mt-4 text-center">
                <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">Back to Search</a>
            </div>
        </div>
    </div>
</div>
